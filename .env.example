# ==============================
# Core
# ==============================
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/despfamiliar

# JWT secret must be long and random (min 32 chars)
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ==============================
# Stripe (Monthly subscription)
# ==============================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# ==============================
# Asaas (Monthly subscription)
# ==============================
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=CHANGE_ME_RANDOM_WEBHOOK_TOKEN

# ==============================
# Email / Password reset
# ==============================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@despfamiliar.com

# ==============================
# OpenAI API (AI-powered insights)
# Get your API key at: https://platform.openai.com/api-keys
# Required for /api/insights and /api/anomalies
# ==============================
OPENAI_API_KEY=

# ==============================
# Web Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# ==============================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@despfamiliar.com

# ==============================
# ==============================
# AWS S3 (Receipt uploads)
# ==============================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=despfamiliar-receipts

# ==============================
# WebSocket Server (Real-time collaboration)
# ==============================
WS_PORT=3001

# ==============================
# Optional local dev bootstrap
# Keep disabled in production
# ==============================
ENABLE_DEV_ADMIN_BOOTSTRAP=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
